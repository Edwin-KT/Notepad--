<Window x:Class="Notepad__.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Notepad__.ViewModels"
		xmlns:helpers="clr-namespace:Notepad__.Helpers"
        Title="Notepad--" Height="600" Width="900">

	<Window.DataContext>
		<vm:MainViewModel/>
	</Window.DataContext>

	<Window.InputBindings>
		<KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewFileCommand}"/>
		<KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
		<KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveFileCommand}"/>
		<KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveFileAsCommand}"/>
		<KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding FindCommand}"/>
		<KeyBinding Key="H" Modifiers="Ctrl" Command="{Binding ReplaceCommand}"/>
		<KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
	</Window.InputBindings>

	<Window.Resources>
		<helpers:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
	</Window.Resources>

	<DockPanel>

		<!-- MENIU -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="File">
				<MenuItem Header="New File"         Command="{Binding NewFileCommand}"/>
				<Separator/>
				<MenuItem Header="Open File..."     Command="{Binding OpenFileCommand}"/>
				<Separator/>
				<MenuItem Header="Save File"        Command="{Binding SaveFileCommand}"/>
				<MenuItem Header="Save File As..."  Command="{Binding SaveFileAsCommand}"/>
				<Separator/>
				<MenuItem Header="Close All Files"  Command="{Binding CloseAllTabsCommand}"/>
				<Separator/>
				<MenuItem Header="Exit"             Command="{Binding ExitCommand}"/>
			</MenuItem>
			<MenuItem Header="Search">
				<MenuItem Header="Find..."
              Command="{Binding FindCommand}"/>
				<MenuItem Header="Replace..."
              Command="{Binding ReplaceCommand}"/>
				<MenuItem Header="Replace All..."
              Command="{Binding ReplaceAllCommand}"/>
				<Separator/>
				<!-- Acest item arata modul curent si il schimba la click -->
				<MenuItem Header="{Binding SearchModeHeader}"
              Command="{Binding ToggleSearchModeCommand}"/>
			</MenuItem>
			<MenuItem Header="View">
				<MenuItem Header="Standard"
              Command="{Binding ShowStandardViewCommand}"/>
				<MenuItem Header="Folder Explorer"
              Command="{Binding ShowFolderExplorerCommand}"/>
			</MenuItem>
			<MenuItem Header="Help">
				<MenuItem Header="About" Command="{Binding AboutCommand}"/>
			</MenuItem>
		</Menu>

		<ToolBar DockPanel.Dock="Top">

			<!-- File operations -->
			<Button Command="{Binding NewFileCommand}"
            ToolTip="New File (Ctrl+N)">
				<TextBlock Text="🗋" FontSize="14"/>
			</Button>

			<Button Command="{Binding OpenFileCommand}"
            ToolTip="Open File (Ctrl+O)">
				<TextBlock Text="📂" FontSize="14"/>
			</Button>

			<Button Command="{Binding SaveFileCommand}"
            ToolTip="Save File (Ctrl+S)">
				<TextBlock Text="💾" FontSize="14"/>
			</Button>

			<Separator/>

			<!-- Search operations -->
			<Button Command="{Binding FindCommand}"
            ToolTip="Find (Ctrl+F)">
				<TextBlock Text="🔍" FontSize="14"/>
			</Button>

			<Button Command="{Binding ReplaceCommand}"
            ToolTip="Replace (Ctrl+H)">
				<TextBlock Text="🔄" FontSize="14"/>
			</Button>

			<Separator/>

			<!-- View operations -->
			<Button Command="{Binding ShowFolderExplorerCommand}"
            ToolTip="Show Folder Explorer">
				<TextBlock Text="📁" FontSize="14"/>
			</Button>

			<Button Command="{Binding ShowStandardViewCommand}"
            ToolTip="Standard View">
				<TextBlock Text="📄" FontSize="14"/>
			</Button>

		</ToolBar>

		<!-- ZONA PRINCIPALA: Explorer stanga + Taburi dreapta -->
		<Grid>
			<Grid.ColumnDefinitions>
				<!-- Coloana pentru explorer; se ascunde cand FolderExplorerVisible = false -->
				<ColumnDefinition Width="{Binding FolderExplorerVisible, 
                                  Converter={StaticResource BoolToWidthConverter}}"/>
				<ColumnDefinition Width="5"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- FOLDER EXPLORER -->
			<TreeView Grid.Column="0"
			ItemsSource="{Binding FileSystemVM.Drives}"
			MouseDoubleClick="TreeView_MouseDoubleClick"
			SelectedItemChanged="TreeView_SelectedItemChanged">

				<TreeView.ItemTemplate>
					<HierarchicalDataTemplate ItemsSource="{Binding Children}">
						<TextBlock Text="{Binding Name}"/>
					</HierarchicalDataTemplate>
				</TreeView.ItemTemplate>

				<TreeView.ItemContainerStyle>
					<Style TargetType="TreeViewItem">
						<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
						<Setter Property="Tag" Value="{Binding DataContext.FileSystemVM, 
                                  RelativeSource={RelativeSource AncestorType=TreeView}}"/>
						<Setter Property="ContextMenu">
							<Setter.Value>
								<!-- Meniul apare doar pe directoare -->
								<ContextMenu>
									<!-- Trucul: legam DataContext-ul meniului la FileSystemViewModel
                             prin PlacementTarget (elementul pe care s-a dat click dreapta),
                             care are DataContext = MainViewModel, din care luam FileSystemVM -->
									<ContextMenu.DataContext>
										<Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource Self}"/>
									</ContextMenu.DataContext>

									<MenuItem Header="New file"
                                  Command="{Binding NewFileInFolderCommand}"/>
									<MenuItem Header="Copy path"
                                  Command="{Binding CopyPathCommand}"/>
									<MenuItem Header="Copy folder"
                                  Command="{Binding CopyFolderCommand}"/>
									<MenuItem Header="Paste folder"
                                  Command="{Binding PasteFolderCommand}"/>
								</ContextMenu>
							</Setter.Value>
						</Setter>
					</Style>
				</TreeView.ItemContainerStyle>
			</TreeView>

			<!-- SEPARATOR VIZUAL -->
			<GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

			<!-- TABURI -->
			<TabControl Grid.Column="2"
            ItemsSource="{Binding Tabs}"
            SelectedItem="{Binding SelectedTab}">

				<TabControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
                       Margin="0,0,5,0"
                       Text="{Binding Header}">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Style.Triggers>
											<!-- Daca IsModified = true, textul devine rosu -->
											<DataTrigger Binding="{Binding IsModified}" Value="True">
												<Setter Property="Foreground" Value="Red"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
							<Button Content="✕"
                    Width="16" Height="16"
                    FontSize="10"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Command="{Binding DataContext.CloseTabCommand,
                              RelativeSource={RelativeSource AncestorType=TabControl}}"
                    CommandParameter="{Binding}"/>
						</StackPanel>
					</DataTemplate>
				</TabControl.ItemTemplate>

				<TabControl.ContentTemplate>
					<DataTemplate>
						<TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"/>
					</DataTemplate>
				</TabControl.ContentTemplate>

			</TabControl>
		</Grid>

	</DockPanel>
</Window>