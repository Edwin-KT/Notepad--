<Window x:Class="Notepad__.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find / Replace"
        Height="220" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
	<StackPanel Margin="15">

		<!-- Find -->
		<Grid Margin="0,0,0,8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="80"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<TextBlock Text="Find:" VerticalAlignment="Center"/>
			<TextBox x:Name="FindBox" Grid.Column="1"/>
		</Grid>

		<!-- Replace (se ascunde in modul Find) -->
		<Grid Margin="0,0,0,12" x:Name="ReplacePanel">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="80"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<TextBlock Text="Replace:" VerticalAlignment="Center"/>
			<TextBox x:Name="ReplaceBox" Grid.Column="1"/>
		</Grid>

		<!-- Butoane -->
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button x:Name="FindBtn"
                    Content="Find"
                    Width="90" Margin="0,0,8,0"
                    Click="FindBtn_Click"/>
			<Button x:Name="ReplaceBtn"
                    Content="Replace"
                    Width="90" Margin="0,0,8,0"
                    Click="ReplaceBtn_Click"/>
			<Button x:Name="ReplaceAllBtn"
                    Content="Replace All"
                    Width="90" Margin="0,0,8,0"
                    Click="ReplaceAllBtn_Click"/>
			<Button Content="Close"
                    Width="70"
                    Click="CloseBtn_Click"/>
		</StackPanel>

		<!-- Mesaj rezultat (ex: "3 replacements made") -->
		<TextBlock x:Name="ResultText"
                   Margin="0,12,0,0"
                   Foreground="Gray"
                   FontStyle="Italic"/>
	</StackPanel>
</Window>