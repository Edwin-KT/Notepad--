<Window x:Class="Notepad__.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="130" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
	<StackPanel Margin="15">
		<TextBlock x:Name="MessageText" Margin="0,0,0,8"/>
		<TextBox x:Name="ResponseBox" Margin="0,0,0,10"/>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="OK"     Width="70" Margin="0,0,8,0" Click="OK_Click"/>
			<Button Content="Cancel" Width="70"                   Click="Cancel_Click"/>
		</StackPanel>
	</StackPanel>
</Window>